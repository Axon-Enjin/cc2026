# Ciel AI Service Environment Variables
# Copy this file to .env and fill in your actual values

# Environment
ENVIRONMENT=development

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Microsoft Foundry Configuration (GPT-only runtime — see cr-ciel-002)
# Get these from: https://portal.azure.com (your Microsoft Foundry resource)
FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com
FOUNDRY_API_KEY=your_foundry_api_key_here
# Single GPT deployment serves both ToC generation and the adversarial critique.
FOUNDRY_DEPLOYMENT_GPT=gpt-5.4
FOUNDRY_API_VERSION=2025-04-01-preview
# GPT-5.x are reasoning models (no temperature; uses max_completion_tokens +
# reasoning_effort). Set false for a classic gpt-4o-class deployment.
FOUNDRY_REASONING_MODEL=true
FOUNDRY_REASONING_EFFORT_GENERATION=medium
FOUNDRY_REASONING_EFFORT_CRITIQUE=high

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Token Budget (per SDD §8)
MAX_TOKENS_TOC_GENERATION=12000
MAX_TOKENS_CRITIQUE=10000
MAX_TOKENS_GRANT_SECTION=6000

# Feature Flags
ENABLE_TOC_CRITIQUE=true
ENABLE_STREAMING=true

# Logging
LOG_LEVEL=INFO

# Client proxy (set in client/.env.local as AI_SERVICE_URL=http://localhost:8000)
